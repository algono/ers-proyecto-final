---
import { COPYRIGHT_YEARS, AUTHORS_WITH_GITHUB_URLS } from "@constants";
import { getAriaCurrentPage } from "@utils/a11y";

const { t } = Astro.locals;

const footerLinks : { href: string; label: string }[] = [];
---

<footer>
  <nav class="footer-nav">
    <ul>
    {footerLinks.map(link => (
      <li><a href={link.href} class="footer-link" aria-current={getAriaCurrentPage(Astro.url.pathname, link.href)}>{link.label}</a></li>
    ))}
    </ul>
  </nav>
  <span class="copyright-text">
    Copyright © {COPYRIGHT_YEARS}
    <span>
      {AUTHORS_WITH_GITHUB_URLS.map((a, i, arr) => (
        <>
          <span>
            {a.name}
            (<a href={a.githubUrl} target="_blank" rel="noopener noreferrer">{a.githubUser}</a>)
          </span>
          {i < arr.length - 1 ? ', ' : ''}
        </>
      ))}
    </span>
    | {t('copyright_text')}
  </span>
</footer>
<style>
  footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 1.2rem;
    background-color: var(--color-secondary);
    color: var(--color-text-on-secondary);
  }
  .footer-nav > ul {
    list-style: none;
    display: flex;
    gap: 1.5rem;
    margin: 0;
    padding: 0;
  }
  .footer-link {
    color: var(--color-text-on-secondary);
    text-decoration: none;
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }
  .footer-link:hover {
    text-decoration: underline;
  }
  .copyright-text a {
    color: var(--color-primary);
  }
  .copyright-text a:hover {
    filter: brightness(0.8);
  }
</style>
