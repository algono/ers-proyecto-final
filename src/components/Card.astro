---
interface Props {
  title?: string;
  [key: string]: any;
}

const { title, ...attributes } = Astro.props;
---

<li class="card" {...attributes}>
  {title && <h3>{title}</h3>}
  <div class="content"><slot /></div>
</li>

<style>
.card {
  background: #fff;
  border-radius: 1rem;
  margin-bottom: 1.5rem;
  padding: 1.5rem 1.2rem;
  box-shadow: 0 2px 12px rgba(44, 62, 80, 0.07);
  transition: box-shadow 0.2s, border-color 0.2s;
  border: 1px solid transparent;
}

.card:hover {
  box-shadow: 0 12px 24px rgba(44, 62, 80, 0.15);
  border-color: var(--color-secondary);
}

.card h3 {
  margin: 0 0 0.5rem 0;
  font-size: 1.3rem;
  /*color: #4a90e2;*/
  color: var(--color-secondary);
  font-weight: 600;
}

.card .content {
  margin: 0;
  /*color: #34495e;*/
  color: var(--color-text);
  font-size: 1.05rem;
}

@media (max-width: 600px) {
  .card {
    padding: 1rem;
  }

  .card h3 {
    font-size: 1.1rem;
  }

  .card .content {
    font-size: 1rem;
  }
}
</style>
