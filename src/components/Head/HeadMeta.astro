---
import { SEO_TITLE, SEO_DESCRIPTION, SEO_IMAGE } from '@constants';
import { homeNoLocale } from '@utils/url.ts';

// Construimos la URL canónica (sin parámetros raros y forzando cómo queremos que se lea)
// Astro.url.pathname nos da la ruta actual
const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url.origin);

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = SEO_TITLE,
  description = SEO_DESCRIPTION,
  image = SEO_IMAGE,
} = Astro.props;

// URL Absoluta de la Imagen:
// homeNoLocale(image) nos da "/social-preview.png" (está en la carpeta public),
// new URL(...) le pega el dominio: "https://tudominio.com/social-preview.png"
const absoluteImageUrl = new URL(homeNoLocale(image), Astro.site || Astro.url.origin);
---
<title>{title}</title>
<meta name="description" content={description} />

<link rel="canonical" href={canonicalURL.href} />

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL.href} />
<meta property="og:image" content={absoluteImageUrl.href} />

{/*
  Specify image dimensions for better social media previews
  IMPORTANT: Make sure these (1200x630) match the actual dimensions of your image at "/public/social-preview.png"
  (1200x630 is the standard size for social media images)
*/}
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={absoluteImageUrl.href} />