{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist", "data-loaders/*/**/*"],
  "compilerOptions": {
    "paths": {
      "@assets/*": ["./src/assets/*"],
      "@components/*": ["./src/components/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@pages/*": ["./src/pages/*"],
      "@scripts/*": ["./src/scripts/*"],
      "@styles/*": ["./src/styles/*"],
      "@projectTypes/*": ["./src/types/*"], // @types es palabra reservada, así que usamos @projectTypes
      "@utils/*": ["./src/utils/*"],
      "@languages": ["./src/languages.ts"],
      "@constants": ["./src/constants.ts"]
    }
  }
}
